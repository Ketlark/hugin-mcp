# Hugin MCP — environment variables (all optional)
# Copy this file to .env and edit as needed.

# ── SearXNG ──────────────────────────────────────────────────────
# URL of your SearXNG instance (auto-started via docker compose if available)
HUGIN_SEARXNG_URL=http://localhost:8888
# Port for the auto-started SearXNG container
HUGIN_SEARXNG_PORT=8888

# ── ReaderLM-v2 (optional) ───────────────────────────────────────
# LM Studio OpenAI-compatible endpoint
HUGIN_LMSTUDIO_URL=http://localhost:1234
# Model name (must be loaded in LM Studio)
HUGIN_READERLM_MODEL=readerlm-v2-mlx
# Max HTML chars sent to ReaderLM per request
HUGIN_READERLM_MAX_INPUT=15000

# ── Puppeteer (optional) ─────────────────────────────────────────
# Chrome/Chromium path. Auto-detected if not set.
# HUGIN_CHROME_PATH=/usr/bin/google-chrome
# Puppeteer page load timeout in ms
HUGIN_PUPPETEER_TIMEOUT=15000

# ── Cache ────────────────────────────────────────────────────────
# Cache directory (SQLite WAL database)
# HUGIN_CACHE_DIR=.cache
# Cache TTL in seconds (default: 24h)
# HUGIN_CACHE_TTL=86400

# ── Readability ──────────────────────────────────────────────────
# Minimum text content length to consider a page "successfully extracted"
# HUGIN_READABILITY_MIN_CHARS=200
